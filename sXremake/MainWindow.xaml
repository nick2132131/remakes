<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Synapse_UI_WPF"
        x:Class="Synapse_UI_WPF.MainWindow"
        mc:Ignorable="d"
        Title="Synapse X" ResizeMode="NoResize" SizeToContent="WidthAndHeight"
        UseLayoutRounding="True" Height="355" Width="801"
        Topmost="True" WindowStyle="None"
        Background="#FF333333" Foreground="#FF333333"
        MouseDown="Window_MouseDown" Loaded="Window_Loaded" Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.LayoutTransform>
            <ScaleTransform x:Name="ScaleTransform" ScaleX="1.0" ScaleY="1.0" CenterX="1.0" CenterY="1.0"/>
        </Grid.LayoutTransform>

        <Grid Name="TopBox" HorizontalAlignment="Left" Height="30" Margin="0,0,0,0"
              VerticalAlignment="Top" Width="801" Background="#FF3C3C3C">
            <Label Name="TitleBox" Content="Synapse X - v1.0.0"
                   HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
            <Button Name="CloseButton" Content="X"
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Width="22" Foreground="White" Click="CloseButton_Click"/>
            <Button Name="MiniButton" Content="_"
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Width="22" Foreground="White" Margin="0,0,22,0" Click="MiniButton_Click"/>
            <!-- Logo set in code-behind to avoid XAML path issues -->
            <Image x:Name="IconBox" HorizontalAlignment="Left" Margin="4,3,0,0"
                   VerticalAlignment="Top" Width="24" Height="24"
                   MouseLeftButtonDown="IconBox_MouseLeftButtonDown"/>
        </Grid>

        <!-- Monaco created in code-behind so XAML compiler never needs CefSharp -->
        <ContentControl x:Name="BrowserHost" RenderOptions.BitmapScalingMode="HighQuality"
                        HorizontalAlignment="Left" Height="272" Margin="10,4.6,0,0"
                        Grid.Row="1" VerticalAlignment="Top" Width="658"/>

        <ListBox Name="ScriptBox" BorderThickness="0" HorizontalAlignment="Left"
                 Height="272" Margin="673,4.6,0,0" Grid.Row="1" VerticalAlignment="Top"
                 Width="122" Background="#FF3C3C3C" Foreground="White">
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Name="ExecuteItem"  Header="Execute"        Click="ExecuteItem_Click"/>
                    <MenuItem Name="LoadItem"     Header="Load to Editor" Click="LoadItem_Click"/>
                    <MenuItem Name="RefreshItem"  Header="Refresh"        Click="RefreshItem_Click"/>
                </ContextMenu>
            </ListBox.ContextMenu>
        </ListBox>

        <Button Name="ExecuteButton"    Content="Execute"      Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" HorizontalAlignment="Left" Margin="10,281.6,0,0"   Grid.Row="1" VerticalContentAlignment="Center" VerticalAlignment="Top" Width="91"  Height="33" Background="#FF3C3C3C" Foreground="White" FontSize="14" Click="ExecuteButton_Click"/>
        <Button Name="ClearButton"      Content="Clear"        Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" HorizontalAlignment="Left" Margin="106,281.6,0,0"  Grid.Row="1" VerticalContentAlignment="Center" VerticalAlignment="Top" Width="91"  Height="33" Background="#FF3C3C3C" Foreground="White" FontSize="14" Click="ClearButton_Click"/>
        <Button Name="OpenFileButton"   Content="Open File"    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" HorizontalAlignment="Left" Margin="202,281.6,0,0"  Grid.Row="1" VerticalContentAlignment="Center" VerticalAlignment="Top" Width="91"  Height="33" Background="#FF3C3C3C" Foreground="White" FontSize="14" Click="OpenFileButton_Click"/>
        <Button Name="ExecuteFileButton" Content="Execute File" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" HorizontalAlignment="Left" Margin="298,281.6,0,0" Grid.Row="1" VerticalContentAlignment="Center" VerticalAlignment="Top" Width="91"  Height="33" Background="#FF3C3C3C" Foreground="White" FontSize="14" Click="ExecuteFileButton_Click"/>
        <Button Name="SaveFileButton"   Content="Save File"    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" HorizontalAlignment="Left" Margin="394,281.6,0,0"  Grid.Row="1" VerticalContentAlignment="Center" VerticalAlignment="Top" Width="91"  Height="33" Background="#FF3C3C3C" Foreground="White" FontSize="14" Click="SaveFileButton_Click"/>
        <Button Name="OptionsButton"    Content="Options"      Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" HorizontalAlignment="Left" Margin="490,281.6,0,0"  Grid.Row="1" VerticalContentAlignment="Center" VerticalAlignment="Top" Width="91"  Height="33" Background="#FF3C3C3C" Foreground="White" FontSize="14" Click="OptionsButton_Click"/>
        <Button Name="AttachButton"     Content="Attach"       Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" HorizontalAlignment="Left" Margin="608,281.6,0,0"  Grid.Row="1" VerticalContentAlignment="Center" VerticalAlignment="Top" Width="91"  Height="33" Background="#FF3C3C3C" Foreground="White" FontSize="14" Click="AttachButton_Click"/>
        <Button Name="ScriptHubButton"  Content="Script Hub"   Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" HorizontalAlignment="Left" Margin="704,281.6,0,0"  Grid.Row="1" VerticalContentAlignment="Center" VerticalAlignment="Top" Width="91"  Height="33" Background="#FF3C3C3C" Foreground="White" FontSize="14" Click="ScriptHubButton_Click"/>

        <!-- Shitty hack. -->
        <Label Name="BottomControl" Visibility="Hidden" Content="AAA"
               HorizontalAlignment="Left" Margin="10,312.6,0,2.2" Grid.Row="1" FontSize="1"/>
    </Grid>
</Window>
